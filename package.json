{
  "name": "shopdirect-frontend-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:migration": "tsc -p tsconfig.migration.json --noEmit",
    "verify:migration": "npm run build && npm run test && npm run lint && npm run typecheck:migration"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
